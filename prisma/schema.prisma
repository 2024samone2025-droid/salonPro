generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Salon {
  id                String   @id @default(cuid())
  name              String
  subdomain         String   @unique
  plan              String   @default("free") // free, pro
  stripeCustomerId  String?
  stripeSubscriptionId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customers     Customer[]
  staff         Staff[]
  services      Service[]
  appointments  Appointment[]
  payments      Payment[]
  users         User[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@index([phone])
  @@index([name])
  @@index([salonId])
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  phone     String   @default("")
  role      String   @default("stylist") // stylist, receptionist
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointments Appointment[]
  users        User[]

  @@index([role])
  @@index([salonId])
}

model Service {
  id        String   @id @default(cuid())
  name      String
  price     Float    // in RWF
  duration  Int      // in minutes
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@index([name])
  @@index([salonId])
}

model Appointment {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD format for easy querying
  startTime String   // HH:mm format
  endTime   String   // HH:mm format
  status    String   @default("booked") // booked, confirmed, in_progress, completed, no_show
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  staffId String
  staff   Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  payment    Payment?

  @@index([date])
  @@index([status])
  @@index([staffId])
  @@index([customerId])
  @@index([salonId])
}

model Payment {
  id            String      @id @default(cuid())
  status        String      @default("unpaid") // unpaid, partial, paid
  method        String      @default("cash") // cash, mtn_momo, airtel_money
  amount        Float      @default(0) // amount paid in RWF
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([method])
  @@index([salonId])
}

model User {
  id        String   @id @default(cuid())
  name      String
  pin       String   // SHA-256 hashed PIN
  role      String   @default("receptionist") // admin, receptionist, stylist
  active    Boolean  @default(true)
  staffId   String?  // optional link to Staff record
  staff     Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([role])
  @@index([pin])
  @@index([salonId])
}
