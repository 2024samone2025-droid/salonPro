generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Salon {
  id                String   @id @default(cuid())
  name              String
  subdomain         String   @unique
  plan              String   @default("free") // free, pro
  stripeCustomerId  String?
  stripeSubscriptionId String?
  settings          Json?    // SalonSettings: businessHours, slotIntervalMinutes, publicBookingEnabled, currency
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customers     Customer[]
  staff         Staff[]
  services      Service[]
  appointments  Appointment[]
  payments      Payment[]
  users         User[]
  owners        OwnerSalon[]
  activityLogs  ActivityLog[]
  daysOff       DayOff[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@index([phone])
  @@index([name])
  @@index([salonId])
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  phone     String   @default("")
  role      String   @default("stylist") // stylist, receptionist
  active    Boolean  @default(true)
  // Optional weekly working-hours template (StaffAvailability JSON, read via
  // parseStaffAvailability). null = follows salon business hours (no override).
  availability Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointments Appointment[]
  users        User[]
  daysOff      DayOff[]

  @@index([role])
  @@index([salonId])
}

// Admin-recorded whole-day closure that blocks online booking and is written to the
// activity log. staffId null = the whole salon is off (e.g. a public holiday); set =
// just that stylist is off while the rest of the salon books normally. One date per row.
model DayOff {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD (matches Appointment.date)
  reason    String   @default("")
  createdAt DateTime @default(now())

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  staffId String?
  staff   Staff? @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([salonId, date])
  @@index([staffId])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  price       Float    // in RWF
  duration    Int      // in minutes
  active      Boolean  @default(true)
  category    String   @default("") // groups the catalog (e.g. "Hair", "Nails")
  description String   @default("") // client-facing; shown on the public booking page
  onlineBookable Boolean @default(true) // false = front-desk only (hidden from online booking)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@index([name])
  @@index([salonId])
}

model Appointment {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD format for easy querying
  startTime String   // HH:mm format
  endTime   String   // HH:mm format
  status    String   @default("booked") // booked, confirmed, in_progress, completed, no_show
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  staffId String
  staff   Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  payment    Payment?

  @@index([date])
  @@index([status])
  @@index([staffId])
  @@index([customerId])
  @@index([salonId])
}

model Payment {
  id            String      @id @default(cuid())
  status        String      @default("unpaid") // unpaid, partial, paid
  method        String      @default("cash") // cash, mtn_momo, airtel_money
  amount        Float      @default(0) // amount paid in RWF
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([method])
  @@index([salonId])
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone        String? // E.164, set via staff-invite onboarding
  email        String // stored lowercased; unique per salon (see @@unique below)
  passwordHash String // scrypt (salt$hash) via lib/password — same scheme as Owner
  // true = admin set a temporary password; the staff member is forced to choose
  // their own on first login (set on creation; cleared by /api/auth/change-password).
  mustResetPassword Boolean @default(false)
  role      String   @default("receptionist") // admin, receptionist, stylist
  active    Boolean  @default(true)
  // default(true) so existing rows skip the tour; user-creation routes set false explicitly
  tourCompleted Boolean @default(true)
  staffId   String?  // optional link to Staff record
  staff     Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)
  // Per-user personal settings (UserSettings JSON) — read via parseUserSettings()
  settings  Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  invite  StaffInvite? // pending onboarding invite, if any

  // Staff log in scoped to their salon (the Host), so email is unique per-salon —
  // the same email may be staff at more than one salon.
  @@unique([salonId, email])
  @@index([role])
  @@index([salonId])
}

// Global owner identity — sits ABOVE per-salon User rows. An owner authenticates
// at the root domain (email + password) and is granted admin rights to every
// salon they are linked to via OwnerSalon, WITHOUT needing a per-salon User row.
model Owner {
  id           String   @id @default(cuid())
  email        String   @unique // stored lowercased
  passwordHash String   // scrypt (salt$hash) — NOT the SHA-256 used for staff PINs
  name         String
  // true = a temp/placeholder password that should be reset on first login.
  // Set by the backfill script; ENFORCEMENT is a deferred follow-up (the flag is
  // currently an unenforced marker — login still works with the temp password).
  mustResetPassword Boolean @default(false)
  // Per-user personal settings (UserSettings JSON) — read via parseUserSettings()
  settings  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salons OwnerSalon[]
}

// Owner ↔ Salon membership. One owner may run several salons; one salon may have
// several owners. This is the link that grants an owner admin rights to a salon.
model OwnerSalon {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([ownerId, salonId])
  @@index([salonId])
}

// Single-use, short-lived nonce backing the cross-domain session handoff. The
// subject logs in at the root domain; we mint one of these, embed its id (jti) in a
// signed token, and redirect to <salon>.salonpro.me, where it is consumed exactly
// once in exchange for a per-subdomain session cookie.
//
// Exactly ONE of ownerId / userId is set, identifying the subject being handed off:
// ownerId = global Owner (owner flow); userId = per-salon staff User (staff flow).
model OneTimeToken {
  id         String    @id @default(cuid()) // = jti carried in the signed token
  ownerId    String?
  userId     String?
  salonId    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([expiresAt])
}

// One-time, single-use staff onboarding invite. The raw token lives ONLY in the
// link we hand the admin; we store just its sha256 (tokenHash). Name+phone is a
// rate-limited confirmation layer (attempts/lockedUntil) — NOT the boundary.
model StaffInvite {
  id          String    @id @default(cuid())
  userId      String    @unique
  salonId     String
  tokenHash   String    @unique // sha256 hex of the raw token; @unique already indexes it
  expiresAt   DateTime
  consumedAt  DateTime? // single-use; null until accepted (or revoked)
  attempts    Int       @default(0)
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Append-only "who did what, when" feed for owner transparency (Phase 2). Written
// best-effort from inside mutation routes via lib/activity.ts — NEVER in the same
// transaction as the action it records (a logging failure must not roll one back).
// The actor is a denormalized SNAPSHOT (type + id + name + role at write-time), not
// an FK: the actor may be a staff User OR an Owner (no User row), and the trail must
// survive renames/deletes. The human-readable `summary` is built at write-time so the
// feed renders with no joins and stays correct after a target record is deleted.
model ActivityLog {
  id         String   @id @default(cuid())
  actorType  String   // 'staff' | 'owner'
  actorId    String   // User.id or Owner.id — intentionally NOT a foreign key
  actorName  String   // snapshot at write-time
  actorRole  String   // snapshot: admin | receptionist | stylist | owner
  action     String   // e.g. 'appointment.confirmed' — see ACTIVITY_ACTIONS
  targetType String?  // 'appointment' | 'payment' | 'user' | 'staff'
  targetId   String?
  summary    String   // human-readable sentence, built at write-time
  metadata   Json?    // optional details: { from, to } | { amount, method } | ...
  createdAt  DateTime @default(now())

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId, createdAt])
}
